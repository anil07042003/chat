# Backend URL for API requests and Socket.IO
#
# LOCAL DEV (default — leave blank or set to localhost):
# VITE_SERVER_URL=http://localhost:3001
#
# MOBILE / SAME WI-FI NETWORK:
# Find your machine's local IP (e.g. ipconfig on Windows, ifconfig on Mac/Linux)
# then set: VITE_SERVER_URL=http://192.168.1.X:3001
#
# VS CODE FORWARDED PORT:
# Forward port 3001 in VS Code PORTS tab, then set the public URL:
# VITE_SERVER_URL=https://xxxx-3001.app.github.dev
#
# Leave blank to use auto-detection (works for most cases):
VITE_SERVER_URL=
